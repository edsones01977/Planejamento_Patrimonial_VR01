/* EVOLUÇÃO */
function renderEvolucao(c) {
    const cfg = c.evolucaoConfig;
    const jReal = juroRealAA(cfg.juroNominalAA, cfg.inflacaoAA);
    const taxaMensal = (Math.pow(1 + jReal, 1/12) - 1) * (1 - cfg.fatorTributacaoIR);
    
    document.getElementById('ev-juro').value = (cfg.juroNominalAA * 100).toFixed(1);
    document.getElementById('ev-infla').value = (cfg.inflacaoAA * 100).toFixed(1);
    document.getElementById('calc-juro-real').innerText = (jReal * 100).toFixed(2) + "% a.a.";

    const recTotal = c.receitas.reduce((s, r) => s + r.valorMensal, 0);
    const desTotal = c.despesas.reduce((s, d) => s + d.valorMensal, 0);
    const aporteMensal = recTotal - desTotal;

    let patrim = c.ativos.reduce((s, a) => s + a.valorMercado, 0);
    const idadeIni = calcularIdade(c.dados.dataNascTitular);
    
    let html = '';
    const labels = [];
    const dataPoints = [];

    for (let i = 0; i <= (100 - idadeIni); i++) {
        const idade = idadeIni + i;
        const ano = new Date().getFullYear() + i;
        const patrimIni = patrim;
        
        const patrimFim = -fv(taxaMensal, 12, aporteMensal, patrimIni);
        const rendim = patrimFim - patrimIni - (aporteMensal * 12);
        
        if (i % 5 === 0 || i < 5) {
            html += `<tr>
                <td>${idade}</td>
                <td>${ano}</td>
                <td>${fmtBRL(patrimIni)}</td>
                <td>${fmtBRL(aporteMensal * 12)}</td>
                <td>${fmtBRL(rendim)}</td>
                <td>${fmtBRL(patrimFim)}</td>
            </tr>`;
        }
        
        labels.push(idade);
        dataPoints.push(patrimFim);
        patrim = patrimFim;
        if (patrim < 0) break;
    }
    document.getElementById('body-evolucao').innerHTML = html;

    const ctx = document.getElementById('chart-evolucao').getContext('2d');
    if (window.myChartEv) window.myChartEv.destroy();

    let gradient = ctx.createLinearGradient(0, 0, 0, 400);
    gradient.addColorStop(0, 'rgba(31, 58, 95, 0.2)'); 
    gradient.addColorStop(1, 'rgba(31, 58, 95, 0.0)'); 

    window.myChartEv = new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{ 
                label: 'Patrimônio Estimado', 
                data: dataPoints, 
                borderColor: '#1F3A5F', 
                borderWidth: 3,
                pointBackgroundColor: '#ffffff',
                pointBorderColor: '#1F3A5F',
                pointBorderWidth: 2,
                pointRadius: 0, 
                pointHoverRadius: 6, 
                fill: true, 
                backgroundColor: gradient,
                tension: 0.4 
            }]
        },
        options: { 
            responsive: true, 
            maintainAspectRatio: false,
            interaction: {
                mode: 'index',
                intersect: false,
            },
            plugins: {
                legend: { display: false }, 
                tooltip: {
                    backgroundColor: '#1F3A5F',
                    padding: 12,
                    titleFont: { size: 13, weight: 'normal' },
                    bodyFont: { size: 14, weight: 'bold' },
                    displayColors: false,
                    callbacks: {
                        title: function(context) { return `Idade: ${context[0].label} anos`; },
                        label: function(context) { return fmtBRL(context.raw); }
                    }
                }
            },
            scales: {
                x: {
                    grid: { display: false }, 
                    title: { display: true, text: 'Idade', font: { size: 12 } }
                },
                y: {
                    border: { display: false },
                    grid: { 
                        color: '#e2e8f0',
                        drawTicks: false,
                        borderDash: [5, 5] 
                    },
                    ticks: {
                        callback: function(value) { return formatAbreviado(value); },
                        padding: 10
                    }
                }
            }
        }
    });
}

