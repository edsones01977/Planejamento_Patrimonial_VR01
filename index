/* RISCOS */
function renderRiscos(c) {
    const suc = calcularSucessao(c);
    const jReal = juroRealAA(c.evolucaoConfig.juroNominalAA, c.evolucaoConfig.inflacaoAA);
    const recTitular = c.receitas.filter(r => r.titular === 'titular').reduce((s,r) => s + r.valorMensal, 0);
    
    const riscos = [
        { nome: 'Morte (Custos Sucessão)', calc: 'Custo Inventário', nec: suc.custoTitular },
        { nome: 'Invalidez Permanente', calc: 'Renda Titular / Juro Real', nec: (recTitular * 12) / (jReal || 0.01) },
        { nome: 'Doenças Graves', calc: '12 meses de Despesas', nec: c.despesas.reduce((s,d)=>s+d.valorMensal, 0) * 12 }
    ];

    document.getElementById('body-riscos').innerHTML = riscos.map(r => `
        <tr>
            <td>${r.nome}</td>
            <td><small>${r.calc}</small></td>
            <td>${fmtBRL(r.nec)}</td>
            <td>${fmtBRL(0)}</td>
            <td class="negative">${fmtBRL(r.nec)}</td>
            <td><span class="badge badge-danger">CONTRATAR</span></td>
        </tr>
    `).join('');
}

/* ==========================================================================
   SISTEMA DE ARQUIVOS & PERSISTÊNCIA
   ========================================================================== */

function save() {
    localStorage.setItem('planpatr_data_v3', JSON.stringify(state));
}

function load() {
    const saved = localStorage.getItem('planpatr_data_v3');
    if (saved) {
        state = JSON.parse(saved);
        if (state.activeClientId) setActiveClient(state.activeClientId);
        else renderClients();
    }
}

function exportData() {
    const blob = new Blob([JSON.stringify(state, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `planejamento_${new Date().toISOString().split('T')[0]}.json`;
    a.click();
}

function importData(event) {
    const file = event.target.files[0];
    const reader = new FileReader();
    reader.onload = (e) => {
        try {
            state = JSON.parse(e.target.result);
            save();
            location.reload();
        } catch (err) { alert("Erro ao importar arquivo JSON."); }
    };
    reader.readAsText(file);
}

function deleteClient(id, event) {
    event.stopPropagation();
    if (confirm("Deseja realmente excluir este cliente?")) {
        state.clients = state.clients.filter(c => c.id !== id);
        if (state.activeClientId === id) state.activeClientId = null;
        save();
        renderClients();
    }
}

function showToast(msg) {
    const t = document.getElementById('toast');
    t.innerText = msg;
    t.style.display = 'block';
    setTimeout(() => t.style.display = 'none', 3000);
}

